---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductInquiryForm from '../../components/ProductInquiryForm.astro';
import { DIRECTUS_URL, directusAssetUrl, directusFetch, directusItemsUrl } from '../../lib/directus';
import { buildBrandLogoMap, buildProductSlugMap, getProductTitle, resolveProductThumbnailSrc } from '../../lib/products';
import { slugifyLabel } from '../../lib/slug';

const DEFAULT_PRODUCT_IMAGE = 'https://battistel.prometeo.com/assets/929fe30e-dd29-4d56-99fe-d34325d9d70b';
const CATEGORY_CARD_IMAGE = 'https://battistel.prometeo.com/assets/e7001235-1819-4d98-93c1-c011be320ce8';

type Category = {
	id?: number | string;
	titolo_categoria?: string;
	descrizione_categoria?: string;
	immagine_categoria?: unknown;
	immagine?: unknown;
	image?: unknown;
	parent_categoria?: unknown;
	parent?: unknown;
	parent_id?: unknown;
	categoria_padre?: unknown;
	categoria_padre_id?: unknown;
};

type CategoryRelation = {
	Categorie_id?: Category | number | null;
};

type Variant = {
	id?: number;
	codice_variante?: string;
	diametro_fresa?: string;
	diametro_gambo?: string;
	lunghezza_totale?: string;
	lunghezza_tagliente?: string;
	z?: string;
	prezzo?: number | string;
};

type VariantRelation = {
	Varianti_id?: Variant | number | null;
};

type Tag = {
	id?: number;
	titolo_tag?: string;
};

type TagRelation = {
	Tags_id?: Tag | number | null;
};

type Product = {
	id?: number;
	status?: string;
	titolo?: string;
	codice_prodotto?: string;
	descrizione_breve?: string;
	descrizione_estesa?: string;
	imballo?: string;
	foto_prodotto?: string;
	Categoria?: CategoryRelation[];
	Categoria_correlata?: CategoryRelation[];
	varianti_prodotto?: VariantRelation[];
	Tag?: TagRelation[];
	[key: string]: unknown;
};

type Brand = {
	id?: number | string;
	logo_marchio?: unknown;
	logo?: unknown;
	immagine?: unknown;
	image?: unknown;
};

type ProductsPage = {
	status?: string;
	slug?: string;
	title?: string;
	Titolo?: string;
	hide_page_header?: boolean;
	featured_image?: string;
};

async function fetchProductsPage(): Promise<ProductsPage | null> {
	try {
		const url = directusItemsUrl('pages');
		url.searchParams.set('fields', 'title,Titolo,hide_page_header,featured_image');
		url.searchParams.set('filter[status][_eq]', 'published');
		url.searchParams.set('filter[slug][_eq]', 'prodotti');
		url.searchParams.set('limit', '1');
		const response = await directusFetch(url);
		if (!response.ok) return null;
		const payload = await response.json();
		const pages = Array.isArray(payload?.data) ? (payload.data as ProductsPage[]) : [];
		return pages[0] ?? null;
	} catch (error) {
		console.error('Errore caricando la pagina prodotti:', error);
		return null;
	}
}

async function fetchProducts(): Promise<Product[]> {
	try {
		const url = directusItemsUrl('Prodotti');
		url.searchParams.set('fields', '*,Categoria.Categorie_id.*,Tag.Tags_id.*');
		url.searchParams.set('filter[status][_eq]', 'published');
		url.searchParams.set('limit', '-1');
		url.searchParams.set('sort', 'sort,codice_prodotto');
		const response = await directusFetch(url);
		if (!response.ok) return [];
		const payload = await response.json();
		return Array.isArray(payload?.data) ? (payload.data as Product[]) : [];
	} catch (error) {
		console.error('Errore caricando i prodotti correlati:', error);
		return [];
	}

}

async function fetchBrands(): Promise<Brand[]> {
	try {
		const url = directusItemsUrl('Marchi');
		url.searchParams.set('fields', 'id,logo_marchio');
		url.searchParams.set('limit', '-1');
		const response = await directusFetch(url);
		if (!response.ok) return [];
		const payload = await response.json();
		return Array.isArray(payload?.data) ? (payload.data as Brand[]) : [];
	} catch (error) {
		console.error('Errore caricando i marchi:', error);
		return [];
	}
}

function getCategories(product: Product) {
	if (!Array.isArray(product?.Categoria)) return [];
	return product.Categoria
		.map((entry) => {
			const category = entry?.Categorie_id && typeof entry.Categorie_id === 'object' ? entry.Categorie_id : null;
			if (!category || (typeof category.id !== 'number' && typeof category.id !== 'string')) return null;
			return {
				id: category.id,
				titolo: category.titolo_categoria || '',
				slug: slugifyLabel(category.titolo_categoria) || String(category.id),
			};
		})
		.filter((entry): entry is { id: number | string; titolo: string; slug: string } => Boolean(entry));
}

function getRelatedCategories(product: Product) {
	if (!Array.isArray(product?.Categoria_correlata)) return [];
	return product.Categoria_correlata
		.map((entry) => {
			const category = entry?.Categorie_id && typeof entry.Categorie_id === 'object' ? entry.Categorie_id : null;
			if (!category || (typeof category.id !== 'number' && typeof category.id !== 'string')) return null;
			return {
				id: category.id,
				titolo: category.titolo_categoria || '',
				slug: slugifyLabel(category.titolo_categoria) || String(category.id),
			};
		})
		.filter((entry): entry is { id: number | string; titolo: string; slug: string } => Boolean(entry));
}

function resolveAssetId(value: unknown): string {
	if (!value) return '';
	if (typeof value === 'string') return value;
	if (typeof value === 'object' && value) {
		const id = (value as { id?: unknown }).id;
		if (typeof id === 'string') return id;
	}
	return '';
}

function resolveCategoryImageSrc(value: unknown): string {
	const id = resolveAssetId(value);
	if (!id) return CATEGORY_CARD_IMAGE;
	return directusAssetUrl(id, {
		width: 760,
		quality: 72,
		format: 'webp',
	});
}

function resolveToken(value: unknown): string {
	if (typeof value === 'number') return String(value);
	if (typeof value === 'string') return value.trim();
	if (typeof value === 'object' && value) {
		const nestedId = (value as { id?: unknown }).id;
		if (typeof nestedId === 'number') return String(nestedId);
		if (typeof nestedId === 'string') return nestedId.trim();
	}
	return '';
}

function getParentCategoryToken(category: Category): string | null {
	const candidates = [
		category.parent_categoria,
		category.parent,
		category.parent_id,
		category.categoria_padre,
		category.categoria_padre_id,
	] as unknown[];

	for (const candidate of candidates) {
		const token = resolveToken(candidate);
		if (token) return token;
	}

	return null;
}

async function fetchCategories(): Promise<Category[]> {
	try {
		const url = directusItemsUrl('Categorie');
		url.searchParams.set('fields', '*');
		url.searchParams.set('filter[status][_eq]', 'published');
		url.searchParams.set('sort', 'sort,titolo_categoria');
		const response = await directusFetch(url);
		if (!response.ok) return [];
		const payload = await response.json();
		return Array.isArray(payload?.data) ? (payload.data as Category[]) : [];
	} catch (error) {
		console.error('Errore caricando le categorie prodotti:', error);
		return [];
	}
}

function getVariants(product: Product) {
	if (!Array.isArray(product?.varianti_prodotto)) return [];
	return product.varianti_prodotto
		.map((entry) => {
			const variant = entry?.Varianti_id && typeof entry.Varianti_id === 'object' ? entry.Varianti_id : null;
			return variant && typeof variant === 'object' ? variant : null;
		})
		.filter((entry): entry is Variant => Boolean(entry));
}

function getTags(product: Product) {
	if (!Array.isArray(product?.Tag)) return [];
	const tags = product.Tag
		.map((entry) => {
			const tag = entry?.Tags_id && typeof entry.Tags_id === 'object' ? entry.Tags_id : null;
			const label = tag?.titolo_tag?.trim() || '';
			return label || null;
		})
		.filter((entry): entry is string => Boolean(entry));
	return Array.from(new Set(tags));
}

function splitCommaValues(value: string | undefined) {
	if (!value) return [];
	return value
		.split(',')
		.map((entry) => entry.trim())
		.filter(Boolean);
}

function formatPrice(value: number | string | undefined) {
	if (value === undefined || value === null || value === '') return '';
	const parsed = typeof value === 'number' ? value : Number(value);
	if (Number.isNaN(parsed)) return '';
	return new Intl.NumberFormat('it-IT', {
		style: 'currency',
		currency: 'EUR',
		minimumFractionDigits: 2,
	}).format(parsed);
}

export async function getStaticPaths() {
	const url = directusItemsUrl('Prodotti');
	url.searchParams.set('fields', '*,Categoria.Categorie_id.*,Categoria_correlata.Categorie_id.*,varianti_prodotto.Varianti_id.*,Tag.Tags_id.*');
	url.searchParams.set('filter[status][_eq]', 'published');
	url.searchParams.set('limit', '-1');
	const response = await directusFetch(url);
	const payload = await response.json();
	const products = Array.isArray(payload?.data) ? (payload.data as Product[]) : [];
	const slugMap = buildProductSlugMap(products);

	return products
		.filter((product) => typeof product?.id === 'number')
		.map((product) => ({
			params: { slug: slugMap.get(product.id!) || String(product.id) },
			props: { product },
		}));
}

const { product } = Astro.props as { product: Product };
const productsPage = await fetchProductsPage();
const title = getProductTitle(product) || 'Prodotto';
const pageHeaderImage = `${DIRECTUS_URL}/assets/491185c0-ede3-4ffd-b149-5872266922fa`;
const allProducts = await fetchProducts();
const brands = await fetchBrands();
const brandLogoById = buildBrandLogoMap(brands);
const imageSrc = resolveProductThumbnailSrc(product, {
	defaultImage: DEFAULT_PRODUCT_IMAGE,
	brandLogoById,
	width: 1200,
	height: 900,
	quality: 74,
	format: 'webp',
});
const allCategories = await fetchCategories();
const categories = getCategories(product);
const variants = getVariants(product);
const tags = getTags(product);
const packaging = splitCommaValues(product?.imballo);
const relatedCategories = getRelatedCategories(product);
const categoryMap = new Map(
	allCategories
		.map((category) => {
			const token = resolveToken(category.id);
			const label = category.titolo_categoria?.trim() || '';
			if (!token || !label) return null;
			const imageField =
				resolveAssetId((category as { immagine_categoria?: unknown }).immagine_categoria) ||
				resolveAssetId((category as { immagine?: unknown }).immagine) ||
				resolveAssetId((category as { image?: unknown }).image);
			return [
				token,
				{
					token,
					title: label,
					slug: slugifyLabel(label) || token,
					parentToken: getParentCategoryToken(category),
					description: category.descrizione_categoria?.trim() || '',
					imageSrc: resolveCategoryImageSrc(imageField),
				},
			] as const;
		})
		.filter((entry): entry is readonly [string, { token: string; title: string; slug: string; parentToken: string | null; description: string; imageSrc: string }] => Boolean(entry))
);

const relatedCategoryCards = Array.from(
	new Map(
		relatedCategories
			.map((entry) => {
				const node = categoryMap.get(String(entry.id));
				if (!node) return null;
				return [
					node.slug,
					{
						title: node.title,
						description: node.description,
						href: `/prodotti/categoria/${encodeURIComponent(node.slug)}`,
						imageSrc: node.imageSrc || CATEGORY_CARD_IMAGE,
					},
				] as const;
			})
			.filter((entry): entry is readonly [string, { title: string; description: string; href: string; imageSrc: string }] => Boolean(entry))
	)
	.values()
);

const primaryCategory = categories[0] || null;
const breadcrumbCategoryItems = [] as { name: string; href?: string }[];

if (primaryCategory) {
	const chain = [] as { title: string; slug: string }[];
	let currentToken: string | null = resolveToken(primaryCategory.id);
	const visited = new Set<string>();

	while (currentToken && !visited.has(currentToken)) {
		visited.add(currentToken);
		const node = categoryMap.get(currentToken);
		if (!node) break;
		chain.unshift({ title: node.title, slug: node.slug });
		currentToken = node.parentToken;
	}

	breadcrumbCategoryItems.push(
		...chain.map((entry) => ({
			name: entry.title,
			href: `/prodotti/categoria/${encodeURIComponent(entry.slug)}`,
		}))
	);
}

const backCategory = breadcrumbCategoryItems[breadcrumbCategoryItems.length - 1];
const backHref = backCategory?.href || '/prodotti';
const backLabel = backCategory?.name ? `Torna a ${backCategory.name}` : 'Torna ai prodotti';
const relatedSlugMap = buildProductSlugMap(allProducts);
const relatedSeed = typeof product.id === 'number' ? product.id : 0;
const relatedProducts = (primaryCategory
	? allProducts
			.filter((entry) => entry.id !== product.id)
			.map((entry) => ({ product: entry, categories: getCategories(entry) }))
			.filter((entry) => entry.categories.some((category) => String(category.id) === String(primaryCategory.id)))
			.sort((a, b) => {
				const aId = typeof a.product.id === 'number' ? a.product.id : 0;
				const bId = typeof b.product.id === 'number' ? b.product.id : 0;
				const aScore = (aId * 37 + relatedSeed * 17) % 997;
				const bScore = (bId * 37 + relatedSeed * 17) % 997;
				if (aScore !== bScore) return aScore - bScore;
				return aId - bId;
			})
			.slice(0, 3)
			.map(({ product: related }) => ({
				title: getProductTitle(related) || 'Prodotto',
				href: `/prodotti/${relatedSlugMap.get(related.id || 0) || String(related.id || '')}`,
				imageSrc: resolveProductThumbnailSrc(related, {
					defaultImage: DEFAULT_PRODUCT_IMAGE,
					brandLogoById,
					width: 1200,
					height: 900,
					quality: 74,
					format: 'webp',
				}),
			}))
	: []);
---

<BaseLayout title={title}>
	<div
		class="page_header"
		style={pageHeaderImage ? `background-image: url('${pageHeaderImage}')` : undefined}
	>
		<div class="page_header_inner">
			<h1 data-aos="fade-up" data-aos-duration="1500">{title}</h1>
		</div>
	</div>

	<section class="product_detail">
		<div class="product_detail_inner">
			<Breadcrumbs
				items={[
					{ name: 'Prodotti', href: '/prodotti' },
					...breadcrumbCategoryItems,
					{ name: title },
				]}
				showGlobalSearch={true}
				showQuoteButton={true}
				searchAction="/prodotti"
				searchPlaceholder="Cerca in tutti i prodotti"
			/>

			<div class="product_hero">
				<div class="product_hero_text">
					{product?.codice_prodotto && <p class="product_code">Codice: {product.codice_prodotto}</p>}
					{product?.descrizione_breve && (
						<p class="product_short">{product.descrizione_breve}</p>
					)}
					<h2 class="product_title">{title}</h2>
					{product?.descrizione_estesa && (
						<p class="product_long">{product.descrizione_estesa}</p>
					)}
					{packaging.length > 0 && (
						<div class="product_pills_group">
							<p class="product_pills_label">Imballi disponibili</p>
							<div class="product_pills">
								{packaging.map((item) => (
									<span class="product_pill">{item}</span>
								))}
							</div>
						</div>
					)}
					{tags.length > 0 && (
						<div class="product_pills_group">
							<p class="product_pills_label">Tag associati</p>
							<div class="product_pills">
								{tags.map((item) => (
									<span class="product_pill">{item}</span>
								))}
							</div>
						</div>
					)}
				</div>
				{imageSrc && (
					<div class="product_hero_media">
						<img src={imageSrc} alt={title} loading="eager" />
					</div>
				)}
			</div>

			{variants.length > 0 && (
				<div class="product_variants">
					<h2 class="product_variants_title">Varianti disponibili</h2>
					<div class="product_variants_table">
						<table>
							<thead>
								<tr>
									<th>Codice variante</th>
									<th>Diametro fresa</th>
									<th>Diametro gambo</th>
									<th>Lunghezza totale</th>
									<th>Lunghezza tagliente</th>
									<th>Z</th>
									<th>Prezzo</th>
								</tr>
							</thead>
							<tbody>
								{variants.map((variant) => (
									<tr>
										<td>{variant.codice_variante || '-'}</td>
										<td>{variant.diametro_fresa || '-'}</td>
										<td>{variant.diametro_gambo || '-'}</td>
										<td>{variant.lunghezza_totale || '-'}</td>
										<td>{variant.lunghezza_tagliente || '-'}</td>
										<td>{variant.z || '-'}</td>
										<td>{formatPrice(variant.prezzo) || '-'}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			)}

			<ProductInquiryForm
				productTitle={title}
				productCode={product?.codice_prodotto || ''}
				categoryName={primaryCategory?.titolo || ''}
			/>

			{relatedCategoryCards.length > 0 && (
				<section class="product_related">
					<div class="product_related_head">
						<h2 class="product_related_title">Categorie correlate</h2>
					</div>

					<div class="product_related_grid">
						{relatedCategoryCards.map((entry) => (
							<a class="product_related_card" href={entry.href}>
								<div class="product_related_media">
									<img src={entry.imageSrc} alt={entry.title} loading="lazy" />
								</div>
								<h3 class="product_related_card_title">{entry.title}</h3>
							</a>
						))}
					</div>
				</section>
			)}

			{relatedProducts.length > 0 && primaryCategory && (
				<section class="product_related">
					<div class="product_related_head">
						<h2 class="product_related_title">Prodotti che potrebbero interessarti</h2>
					</div>

					<div class="product_related_grid">
						{relatedProducts.map((entry) => (
							<a class="product_related_card" href={entry.href}>
								<div class="product_related_media">
									<img src={entry.imageSrc} alt={entry.title} loading="lazy" />
								</div>
								<h3 class="product_related_card_title">{entry.title}</h3>
							</a>
						))}
					</div>

					<a class="product_related_link" href={backHref}>Vedi tutti</a>
				</section>
			)}
		</div>
	</section>
</BaseLayout>

<style>
	.product_detail {
		padding: 24px 20px 70px;
	}

	.product_detail_inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.product_back {
		display: inline-flex;
		margin-bottom: 22px;
		color: var(--nero);
		text-decoration: none;
		font-weight: 600;
		letter-spacing: 0.4px;
		gap: 8px;
	}

	.product_back::before {
		content: '<';
	}

	.product_hero {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 32px;
		background: #fff;
		border-radius: 28px;
		padding: 50px;
		color: #000;
		align-items: center;
		box-shadow: 0 18px 38px rgba(0, 0, 0, 0.12);
	}

	.product_hero_text {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.product_code {
		margin: 0;
		font-weight: 600;
		color: var(--arancione-battistel);
	}

	.product_short {
		margin: 0;
		font-size: 20px;
		line-height: 1.5;
		color: rgba(0, 0, 0, 0.85);
	}

	.product_long {
		margin: 0;
		font-size: 16px;
		line-height: 1.6;
		color: rgba(0, 0, 0, 0.7);
		white-space: pre-line;
	}

	.product_pills_group {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.product_pills_label {
		margin: 0;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.4px;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.6);
	}

	.product_pills {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.product_pill {
		display: inline-flex;
		align-items: center;
		padding: 10px 16px;
		border-radius: 999px;
		background: rgba(0, 84, 166, 0.1);
		color: var(--arancione-battistel);
		font-size: 15px;
		font-weight: 600;
	}

	.product_hero_media {
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product_hero_media img {
		width: 100%;
		height: 100%;
		max-height: 380px;
		object-fit: contain;
		border-radius: 22px;
	}

	.product_variants {
		margin-top: 40px;
		background: #fff;
		border-radius: 24px;
		padding: 32px;
		color: #000;
	}

	.product_related {
		margin-top: 40px;
	}

	.product_related_head {
		margin-bottom: 20px;
	}

	.product_related_title {
		margin: 0;
		font-size: 24px;
		font-weight: 700;
		color: #000;
	}

	.product_related_link {
		display: flex;
		justify-content: center;
		margin-top: 20px;
		color: #d77701;
		font-weight: 700;
		text-decoration: none;
	}

	.product_related_grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.product_related_card {
		display: flex;
		flex-direction: column;
		gap: 14px;
		padding: 24px;
		background: #fff;
		border: 1px solid rgba(0, 0, 0, 0.09);
		border-radius: 14px;
		color: #000;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.product_related_card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
	}

	.product_related_media {
		overflow: hidden;
		border-radius: 10px;
		aspect-ratio: 4 / 3;
		background: #f8f8f8;
	}

	.product_related_media img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.product_related_card_title {
		margin: 0;
		font-size: 22px;
		line-height: 1.15;
		text-align: center;
