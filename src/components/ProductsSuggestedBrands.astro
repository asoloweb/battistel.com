---
import { directusFetch, directusItemsUrl } from '../lib/directus';

type Options = {
	marchi_suggeriti?: string;
};

function extractListItems(value: string) {
	const items = Array.from(value.matchAll(/<li\b[^>]*>([\s\S]*?)<\/li>/gi), (match) => match[1]?.trim() || '')
		.filter(Boolean);

	return items;
}

let suggestedBrands: string[] = [];

try {
	const optionsUrl = directusItemsUrl('options');
	optionsUrl.searchParams.set('fields', 'marchi_suggeriti');
	const optionsResponse = await directusFetch(optionsUrl);
	if (optionsResponse.ok) {
		const optionsPayload = await optionsResponse.json();
		const options =
			optionsPayload?.data && Array.isArray(optionsPayload.data)
				? (optionsPayload.data[0] as Options | undefined)
				: (optionsPayload?.data as Options | undefined);
		const rawHtml = options?.marchi_suggeriti || '';

		suggestedBrands = extractListItems(rawHtml);
	}
} catch (error) {
	console.error('Errore caricando i marchi suggeriti:', error);
}
---

{suggestedBrands.length > 0 && (
	<section class="products_suggested_brands" data-aos="fade-up" data-aos-duration="1500">
		<div class="products_suggested_brands_inner">
			<div class="products_suggested_brands_intro">
				<div class="products_suggested_brands_kicker">Marchi suggeriti</div>
				<h2 class="products_suggested_brands_title">Collaboriamo con i principali fornitori.</h2>
				<p class="products_suggested_brands_text">Scopri il prodotto adatto alle tue esigenze:</p>
			</div>

			<div class="products_suggested_brands_content">
				<div class="products_suggested_brands_list" aria-label="Marchi suggeriti">
					{suggestedBrands.map((brand) => (
						<span class="products_suggested_brands_item" set:html={brand}></span>
					))}
				</div>
			</div>
		</div>
	</section>
)}

<style>
	.products_suggested_brands {
		padding: 0 20px 50px;
	}

	.products_suggested_brands_inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		background: #fff;
		border-radius: 32px;
		overflow: hidden;
		box-shadow: 0 18px 38px rgba(0, 0, 0, 0.12);
	}

	.products_suggested_brands_intro {
		padding: 44px 48px;
		background: linear-gradient(135deg, #0c2f66 0%, #184b99 100%);
		color: #fff;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 18px;
	}

	.products_suggested_brands_kicker {
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.82);
	}

	.products_suggested_brands_title {
		margin: 0;
		font-size: clamp(30px, 3vw, 44px);
		line-height: 1.05;
		font-weight: 700;
	}

	.products_suggested_brands_text {
		margin: 0;
		font-size: 20px;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.92);
	}

	.products_suggested_brands_content {
		padding: 44px 48px;
		display: flex;
		align-items: center;
	}

	.products_suggested_brands_list {
		display: flex;
		flex-direction: column;
		gap: 14px;
		align-items: flex-start;
		width: 100%;
	}

	.products_suggested_brands_item {
		display: inline-flex;
		align-items: center;
		padding: 10px;
		border-radius: 20px;
		background: #f2f2f2;
		border: 0;
		font-size: 18px;
		line-height: 1.2;
		font-weight: 600;
		color: var(--blu);
		width: 100%;
		min-height: 52px;
	}

	:global(.products_suggested_brands_item p) {
		margin: 0;
	}

	:global(.products_suggested_brands_item strong),
	:global(.products_suggested_brands_item a) {
		color: inherit;
		text-decoration: none;
	}

	@media (max-width: 760px) {
		.products_suggested_brands_inner {
			grid-template-columns: 1fr;
		}

		.products_suggested_brands_intro,
		.products_suggested_brands_content {
			padding: 28px 24px;
		}

		.products_suggested_brands_title {
			padding-bottom: 16px;
		}

		.products_suggested_brands_text {
			font-size: 18px;
		}

		.products_suggested_brands_item {
			font-size: 18px;
		}
	}
</style>
