---
import { directusAssetUrl, directusFetch, directusItemsUrl } from '../lib/directus';

type Brand = {
	id?: number;
	nome_marchio?: string;
	logo_marchio?: string | { id?: string | null } | null;
	url_marchio?: string;
	marchio_suggerito?: boolean | number | null;
};

type Options = {
	products_suggested_brands_title_html?: string;
};

function resolveAssetId(value: Brand['logo_marchio']) {
	if (!value) return '';
	if (typeof value === 'string') return value;
	if (typeof value === 'object' && typeof value.id === 'string') return value.id;
	return '';
}

function resolveLogoSrc(value: Brand['logo_marchio']) {
	const id = resolveAssetId(value);
	if (!id) return '';
	return directusAssetUrl(id, {
		width: 360,
		height: 120,
		quality: 82,
		format: 'webp',
	});
}

function resolveBrandUrl(value?: string) {
	const url = (value || '').trim();
	if (!url) return '';
	if (url.startsWith('http://') || url.startsWith('https://')) return url;
	return `https://${url}`;
}

let suggestedBrands: { name: string; logoSrc: string; url: string }[] = [];
let suggestedBrandsTitleHtml = 'Collaboriamo con le principali societa di riferimento.';

try {
	const optionsUrl = directusItemsUrl('options');
	optionsUrl.searchParams.set('fields', 'products_suggested_brands_title_html');
	const optionsResponse = await directusFetch(optionsUrl);
	if (optionsResponse.ok) {
		const optionsPayload = await optionsResponse.json();
		const options = optionsPayload?.data as Options | undefined;
		const titleHtml = options?.products_suggested_brands_title_html?.trim();
		if (titleHtml) suggestedBrandsTitleHtml = titleHtml;
	}

	const brandsUrl = directusItemsUrl('Marchi');
	brandsUrl.searchParams.set('fields', 'id,nome_marchio,logo_marchio,url_marchio,marchio_suggerito');
	brandsUrl.searchParams.set('filter[marchio_suggerito][_eq]', 'true');
	brandsUrl.searchParams.set('sort', 'sort,nome_marchio');
	brandsUrl.searchParams.set('limit', '-1');
	const brandsResponse = await directusFetch(brandsUrl);
	if (brandsResponse.ok) {
		const brandsPayload = await brandsResponse.json();
		const brands = Array.isArray(brandsPayload?.data) ? (brandsPayload.data as Brand[]) : [];
		suggestedBrands = brands
			.map((brand) => ({
				name: brand.nome_marchio?.trim() || '',
				logoSrc: resolveLogoSrc(brand.logo_marchio),
				url: resolveBrandUrl(brand.url_marchio),
			}))
			.filter((brand) => brand.name);
	}
} catch (error) {
	console.error('Errore caricando i marchi suggeriti:', error);
}
---

{suggestedBrands.length > 0 && (
	<section class="products_suggested_brands" data-aos="fade-up" data-aos-duration="1500">
		<div class="products_suggested_brands_inner">
			<div class="products_suggested_brands_intro">
				<div class="products_suggested_brands_kicker">Marchi suggeriti</div>
				<h2 class="products_suggested_brands_title" set:html={suggestedBrandsTitleHtml}></h2>
			</div>

			<div class="products_suggested_brands_content">
				<div class="products_suggested_brands_list" aria-label="Marchi suggeriti">
					{suggestedBrands.map((brand) => (
						brand.url ? (
							<a class="products_suggested_brands_item" title={brand.name} href={brand.url} target="_blank" rel="noopener noreferrer">
								{brand.logoSrc ? (
									<img src={brand.logoSrc} alt={brand.name} loading="lazy" />
								) : (
									<span>{brand.name}</span>
								)}
							</a>
						) : (
							<span class="products_suggested_brands_item" title={brand.name}>
								{brand.logoSrc ? (
									<img src={brand.logoSrc} alt={brand.name} loading="lazy" />
								) : (
									<span>{brand.name}</span>
								)}
							</span>
						)
					))}
				</div>
			</div>
		</div>
	</section>
)}

<style>
	.products_suggested_brands {
		padding: 0 20px 50px;
	}

	.products_suggested_brands_inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		background: #fff;
		border-radius: 32px;
		overflow: hidden;
		box-shadow: 0 18px 38px rgba(0, 0, 0, 0.12);
	}

	.products_suggested_brands_intro {
		padding: 44px 48px;
		background: var(--blu-battistel);
		color: #fff;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 18px;
	}

	.products_suggested_brands_kicker {
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.82);
	}

	.products_suggested_brands_title {
		margin: 0;
		font-size: clamp(30px, 3vw, 44px);
		line-height: 1.05;
		font-weight: 700;
	}

	.products_suggested_brands_content {
		padding: 44px 48px;
		display: flex;
		align-items: center;
	}

	.products_suggested_brands_list {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 50px;
		align-items: flex-start;
		width: 100%;
	}

	.products_suggested_brands_item {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border-radius: 0;
		background: transparent;
		border: 0;
		font-size: 18px;
		line-height: 1.2;
		font-weight: 600;
		color: var(--arancione-battistel);
		width: auto;
		height: 70px;
		min-height: 70px;
		text-decoration: none;
	}

	.products_suggested_brands_item img {
		width: auto;
		height: 70px;
		max-width: 100%;
		object-fit: contain;
	}

	@media (max-width: 760px) {
		.products_suggested_brands_inner {
			grid-template-columns: 1fr;
		}

		.products_suggested_brands_intro,
		.products_suggested_brands_content {
			padding: 28px 24px;
		}

		.products_suggested_brands_title {
			padding-bottom: 16px;
		}

		.products_suggested_brands_item {
			font-size: 18px;
		}
	}
</style>
